# RAPIDS Database Backup Configuration

# Database connection URL (required)
DATABASE_URL=postgresql://rapids:rapids_dev_2024@localhost:5434/rapids_orchestrator

# Backup directory (default: ./backups)
BACKUP_DIR=./backups

# S3 configuration (optional - for remote backups)
S3_BACKUP_BUCKET=rapids-orchestrator-backups
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Backup retention in days (default: 30)
BACKUP_RETENTION_DAYS=30
