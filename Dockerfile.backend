# Multi-stage Dockerfile for RAPIDS Meta-Orchestrator Backend
# Base: Python 3.12 with UV package manager for fast dependency installation

# Stage 1: Builder - Install dependencies
FROM python:3.12-slim AS builder

# Install UV package manager (faster than pip)
RUN pip install --no-cache-dir uv

# Set working directory
WORKDIR /app

# Copy dependency files
COPY pyproject.toml uv.lock ./

# Install dependencies in virtual environment
RUN uv venv /app/.venv && \
    . /app/.venv/bin/activate && \
    uv pip install --no-cache -r pyproject.toml

# Stage 2: Runtime - Minimal production image
FROM python:3.12-slim

# Install security updates and git (needed for git worktrees)
RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends git && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create non-root user for security
RUN useradd -m -u 1000 rapids && \
    mkdir -p /app /app/logs /app/workspace && \
    chown -R rapids:rapids /app

# Set working directory
WORKDIR /app

# Copy virtual environment from builder
COPY --from=builder --chown=rapids:rapids /app/.venv /app/.venv

# Copy application code
COPY --chown=rapids:rapids orchestrator/ /app/orchestrator/
COPY --chown=rapids:rapids auth/ /app/auth/
COPY --chown=rapids:rapids db/ /app/db/
COPY --chown=rapids:rapids workspace/ /app/workspace/
COPY --chown=rapids:rapids .claude/ /app/.claude/
COPY --chown=rapids:rapids CLAUDE.md /app/
COPY --chown=rapids:rapids pyproject.toml /app/

# Switch to non-root user
USER rapids

# Set environment variables
ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    ENVIRONMENT=production

# Expose port (internal)
EXPOSE 9403

# Health check endpoint
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:9403/health').read()"

# Run application with Uvicorn
# Using single worker for Phase 1 (as per architecture doc)
CMD ["uvicorn", "orchestrator.backend.main:app", \
     "--host", "0.0.0.0", \
     "--port", "9403", \
     "--workers", "1", \
     "--log-config", "null"]
