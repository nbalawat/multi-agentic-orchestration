{
  "name": "Stress Test Scenario",
  "description": "Push system beyond normal capacity to find breaking point",
  "target_rps": 2000,
  "duration_seconds": 900,
  "stages": [
    {
      "duration": "2m",
      "users": 200,
      "spawn_rate": 50,
      "description": "Baseline"
    },
    {
      "duration": "3m",
      "users": 1000,
      "spawn_rate": 100,
      "description": "Normal peak capacity"
    },
    {
      "duration": "3m",
      "users": 1500,
      "spawn_rate": 100,
      "description": "Stress level 1"
    },
    {
      "duration": "3m",
      "users": 2000,
      "spawn_rate": 100,
      "description": "Stress level 2"
    },
    {
      "duration": "4m",
      "users": 2500,
      "spawn_rate": 100,
      "description": "Maximum stress"
    }
  ],
  "locust_command": "locust -f locustfile.py --host=http://127.0.0.1:9403 --users=2500 --spawn-rate=100 --run-time=15m --html=reports/stress_report.html --csv=reports/stress"
}
