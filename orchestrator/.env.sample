# RAPIDS Meta-Orchestrator — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.sample .env

# ============================================================================
# AUTHENTICATION (choose one)
# ============================================================================

# Option A: Anthropic API Key (direct API access, billed to your account)
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Option B: Claude Code OAuth Token (uses your Claude Code subscription)
# Get this by running: claude auth login
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-your-token-here

# ============================================================================
# DATABASE
# ============================================================================

# PostgreSQL connection (default: local Docker via docker-compose.yml)
DATABASE_URL=postgresql://rapids:rapids_dev_2024@localhost:5434/rapids_orchestrator

# ============================================================================
# BACKEND
# ============================================================================

BACKEND_HOST=127.0.0.1
BACKEND_PORT=9403

# ============================================================================
# FRONTEND
# ============================================================================

FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5175

# ============================================================================
# MODELS
# ============================================================================

# Orchestrator model (the conductor agent)
ORCHESTRATOR_MODEL=claude-sonnet-4-5-20250929

# Phase-specific model overrides (optional)
# Strategic phases default to Opus, execution phases to Sonnet
# RESEARCH_MODEL=claude-opus-4-20250514
# ANALYSIS_MODEL=claude-opus-4-20250514
# PLAN_MODEL=claude-opus-4-20250514
# IMPLEMENT_MODEL=claude-sonnet-4-5-20250929
# DEPLOY_MODEL=claude-sonnet-4-5-20250929
# SUSTAIN_MODEL=claude-sonnet-4-5-20250929

# ============================================================================
# EXECUTION WORKER
# ============================================================================

# Max parallel builder agents (default: 3)
# MAX_PARALLEL_BUILDERS=3

# Git remote sync (fetch before worktree, push after merge)
# GIT_REMOTE_SYNC=true
# GIT_REMOTE_NAME=origin

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO
LOG_DIR=orchestrator/backend/logs

# ============================================================================
# IDE INTEGRATION
# ============================================================================

# IDE command for opening files (cursor or code)
IDE_COMMAND=code
IDE_ENABLED=true
